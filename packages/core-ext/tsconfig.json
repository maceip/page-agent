{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"declaration": true,
		"declarationDir": "./dist/esm",
		"outDir": "./dist/esm",
		"rootDir": "./src",
		"lib": ["ESNext", "DOM", "DOM.Iterable"]
	},
	"include": ["src/**/*"]
}
