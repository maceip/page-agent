// this is only for IDE ts language server to work.
// do not use this for building or linting.
{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "paths": {
            "@page-agent/page-controller": ["./packages/page-controller/src/PageController.ts"],
            "@page-agent/llms": ["./packages/llms/src/index.ts"],
            "@page-agent/core": ["./packages/core/src/PageAgentCore.ts"],
            "@page-agent/ui": ["./packages/ui/src/index.ts"]
        }
    },
    "references": [
        { "path": "./packages/page-controller" },
        { "path": "./packages/ui" },
        { "path": "./packages/llms" },
        { "path": "./packages/page-agent" },
        { "path": "./packages/website" }
    ],
    "include": ["packages/*/src/**/*.ts", "packages/*/src/**/*.tsx", "tests/**/*.ts"],
    "exclude": ["node_modules", "dist", "packages/*/dist", "packages/extension"]
}
